# ========== ACEA Backend — Environment Variables ==========
# Copy this file to .env and fill in your values.
# 
# LOCAL DEV: Only GEMINI_API_KEYS is required. Everything else has safe defaults.
# PRODUCTION (Railway): Set all variables marked [REQUIRED].

# ---- Environment ----
# Set to "production" on Railway
ENVIRONMENT=development

# ---- API Keys [REQUIRED] ----
GEMINI_API_KEYS=your_key_1,your_key_2
E2B_API_KEY=your_e2b_key

# ---- Database ----
# Local: uses SQLite (default, no setup needed)
# Railway: set to your PostgreSQL URL from Railway add-on
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./acea.db

# ---- Redis ----
# Local: optional (falls back to in-memory)
# Railway: set to your Upstash or Railway Redis URL
# REDIS_URL=redis://default:password@host:port
REDIS_URL=redis://localhost:6379
USE_REDIS_PERSISTENCE=false

# ---- Frontend URL (CORS) ----
# Set to your Vercel deployment URL on Railway
# FRONTEND_URL=https://your-app.vercel.app
FRONTEND_URL=

# ---- Security ----
# MUST change in production!
JWT_SECRET=supersecretkey_change_me_in_production

# ---- Optional ----
CODESANDBOX_API_KEY=
DAYTONA_API_KEY=
